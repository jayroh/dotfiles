#!/bin/bash
# Orchestrator — runs each step under setup.d/ in dependency order.
# Each step under setup.d/ is also runnable standalone.
set -e

cd "$(dirname "$0")"

# Platform-specific package installs (each no-ops on the wrong platform)
./setup.d/pacman
./setup.d/apt
./setup.d/mac

# Cross-platform tooling
./setup.d/shell
./setup.d/mise
./setup.d/bunnai
./setup.d/neovim
./setup.d/tmux
./setup.d/omarchy
./setup.d/rcup

echo ""
echo "✅ Setup complete."
echo ""
echo "Next:"
echo "  $ nvim +'PlugInstall --sync' +qa"
echo "  (macOS) set iTerm's font to 'MesloLGS NF'"
echo "  (Arch)  install fonts:  cp ./misc/*.[ot]tf ~/.local/share/fonts/ && fc-cache -f"
echo ""
