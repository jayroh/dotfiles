[user]
	name = Joel Oliveira
	email = joel.oliveira@gmail.com
[alias]
	a = add -A
	bracnh = branch
	ci = commit -v
	clone = !hub clone
	co = checkout
	continue = rebase --continue
	create = !grb create
	d = "!git diff --cached --color | /usr/local/Cellar/node/5.5.0/bin/diff-so-fancy | less"
	del = !grb rm
	dev = checkout development
	file = log --all --graph\n--pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'\n--abbrev-commit --date=relative
	file-history = log --all --graph\n--pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'\n--abbrev-commit --date=relative
	getpr = "!sh -c 'git fetch origin pull/$0/head:pr-$0 && git co pr-$0'"
	lol = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative -10
	ls = branch
	ma = checkout master
	mas = checkout master
	mine = "!git branch | grep jro"
	theirs = "!git branch -a | grep -v jro | grep -v master"
	p = push
	plul = pull
	pr = !hub pull-request
	praise = blame
	prep = "!git checkout master && git pull origin master && git checkout - && git rebase master"
	puhs = push
	pul = pull
	pus = push
	rebase-origin = !git fetch origin && git rebase origin/master
	rename = !grb rename
	s = status -sb
	squash-origin = !git rebase -i origin/master
	sta = checkout staging
	stats = status
	stauts = status
	sta = checkout staging
	unstage = reset
[color]
	diff = auto
	ui = auto
[core]
	excludesfile = /Users/joel/.gitignore_global
	editor = vim
[color "status"]
	added = yellow
	changed = green
	untracked = cyan
[push]
	default = current
[rerere]
	enabled = 1
[github]
	user = jayroh
[pull]
	rebase = true
[heroku]
	account = joel
[diff]
	compactionHeuristic = true
