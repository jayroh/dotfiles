#!/bin/bash
# Install language-host providers Neovim needs (Ruby gem, Node package, Python pynvim).
set -e

# Ruby: install the neovim gem in every installed Ruby version managed by mise.
if command -v mise &>/dev/null; then
  versions=$(mise ls --installed ruby 2>/dev/null | awk 'NR>1 {print $2}' | grep -v '^$' | sort -u)
  for version in $versions; do
    echo "Installing neovim gem and rubocop in Ruby version: $version"
    mise exec ruby@$version -- gem install neovim rubocop
  done
  # Refresh mise shims so neovim-ruby-host (and any new gem bins) are reachable.
  mise reshim
fi

# Node: install the neovim npm package globally.
if command -v npm &>/dev/null; then
  echo "Installing neovim npm package."
  npm install -g neovim
fi

# Global bun packages for Neovim tooling.
if command -v bun &>/dev/null; then
  echo "Installing bun global packages (oxfmt, mmdc) ..."
  bun install -g oxfmt @mermaid-js/mermaid-cli
fi

# Python: install the pynvim provider into mise's Python, not the system one.
# On Debian/Ubuntu (and recent Arch) the system Python is externally-managed
# (PEP 668), so `pip3 install` is blocked there. mise's standalone Python is
# unmanaged and, via `mise activate`, already shadows /usr/bin on $PATH.
if command -v mise &>/dev/null && mise ls --installed python 2>/dev/null | grep -q .; then
  if ! mise exec python -- python -c "import pynvim" >/dev/null 2>&1; then
    echo "Installing pynvim into mise-managed Python."
    mise exec python -- python -m pip install pynvim
  fi
  # Refresh shims so any console-scripts pip dropped are reachable.
  mise reshim
fi
