#!/bin/bash
# Install bunnai (AI commit-message helper for lazygit) globally via bun.
set -e

if ! command -v bun &>/dev/null; then
  echo "⚠️  bun not on PATH. Run setup.d/mise first (or activate mise in this shell)."
  exit 1
fi

bun install -g @chhoumann/bunnai
echo "⚠️  Now configure bunnai with: bunnai config"
