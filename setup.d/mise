#!/bin/bash
# Install mise and provision runtimes from .tool-versions.
set -e

cd "$(dirname "$0")/.."

# Install mise if not already present
if ! command -v mise &>/dev/null; then
  if [[ "$(uname -s)" == "Darwin" ]] && command -v brew &>/dev/null; then
    echo "Installing mise via Homebrew ..."
    brew install mise
  elif command -v pacman &>/dev/null; then
    echo "Installing mise via pacman ..."
    sudo pacman -S --needed --noconfirm mise
  else
    echo "Installing mise via official installer ..."
    curl -fsSL https://mise.run | sh
    export PATH="$HOME/.local/bin:$PATH"
  fi
fi

echo "Provisioning runtimes from .tool-versions ..."
mise install

echo "Pinning versions globally for tools not in .tool-versions ..."
# python is pinned globally (not in .tool-versions) so a mise-managed
# python/python3/pip/pip3 supersedes the system interpreter user-wide — the
# distro Python is externally-managed (PEP 668) and blocks `pip install`.
mise use -g lazygit@latest bun@latest python@3.13.14

# Optional: uncomment to install other languages globally
# mise use -g golang@latest rust@latest

echo "✅ mise setup complete. Run 'mise current' to verify."
